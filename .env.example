# 服务器主加密密钥。部署时执行：
# python channel_query_app.py --generate-master-key
CHANNEL_QUERY_MASTER_KEY=replace_with_generated_master_key

# 可选：运行时数据目录，用于保存加密 token 和网页草稿。
# Docker Compose 默认使用 /data；裸机部署一般不用改。
# CHANNEL_QUERY_DATA_DIR=/data

# 可选：也可以把机器人和表格配置放到环境变量里。
# TELEGRAM_BOT_TOKEN=123456:replace_with_botfather_token
# TELEGRAM_API_BASE=https://api.telegram.org
# TELEGRAM_ALLOWED_UPDATES=message,my_chat_member
# Docker 可设为 /data/.telegram_chats.json；裸机一般不填，默认在项目目录。
# TELEGRAM_CHAT_REGISTRY_FILE=/data/.telegram_chats.json
# TELEGRAM_BACKUP_DIR=/data/telegram-state-backups
# WPPCHAT_BACKEND_URL=https://zhheew.bw009.com
# CHANNEL_QUERY_SHEET_URL=https://docs.google.com/spreadsheets/d/your_sheet_id/edit?gid=0#gid=0
# CHANNEL_QUERY_SERVICE_ACCOUNT_FILE=/opt/channel-query/service-account.json

# 可选：运行灾备脚本时使用。备份包包含敏感配置，建议加密后再传到备份服务器。
# CHANNEL_QUERY_BACKUP_DIR=/opt/channel-query-backups
# CHANNEL_QUERY_BACKUP_REMOTE=backup-user@backup-server:/srv/backups/channel-query/
# CHANNEL_QUERY_BACKUP_PASSPHRASE_FILE=/root/.channel-query-backup-passphrase
# CHANNEL_QUERY_BACKUP_KEEP=168
